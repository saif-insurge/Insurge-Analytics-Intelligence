# Database
DATABASE_URL=postgresql://postgres:local@localhost:5432/ga4_audit

# Clerk Auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/audits
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/audits

# Stagehand AI navigation
# Format: provider/model
# Direct: openai/gpt-5.4-mini, anthropic/claude-sonnet-4-6, google/gemini-3-flash-preview
# OpenRouter: openrouter/google/gemini-3-flash-preview, openrouter/anthropic/claude-sonnet-4-6
STAGEHAND_MODEL=openai/gpt-5.4-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Database-as-queue scheduler
# Shared secret for the worker dispatch endpoint (web -> Cloud Run worker).
# Generate: openssl rand -hex 32
WORKER_SHARED_SECRET=
# Shared secret for the scheduler tick endpoint (Coolify cron + worker -> web).
# Generate: openssl rand -hex 32
SCHEDULER_TOKEN=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Insurge <onboarding@resend.dev>

# Internal auth (worker <-> web)
INTERNAL_SECRET=

# Service URLs
WEB_BASE_URL=http://localhost:3000
WORKER_BASE_URL=http://localhost:8080

# Proxy (production only — leave empty for local dev)
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Sentry
SENTRY_DSN=

# Tracking pixels (for shareable report pages)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTAG_ID=
