# Database
DATABASE_URL=postgresql://postgres:local@localhost:5432/ga4_audit

# Clerk Auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/audits
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/audits

# Stagehand AI navigation
# Format: provider/model (e.g., openai/gpt-4o, openai/gpt-4.1-mini, anthropic/claude-sonnet-4-6)
STAGEHAND_MODEL=openai/gpt-4.1-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Upstash QStash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Insurge <onboarding@resend.dev>

# Internal auth (worker <-> web)
INTERNAL_SECRET=

# Service URLs
WEB_BASE_URL=http://localhost:3000
WORKER_BASE_URL=http://localhost:8080

# Sentry
SENTRY_DSN=

# Tracking pixels (for shareable report pages)
