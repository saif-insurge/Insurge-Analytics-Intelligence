generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id
  name      String
  createdAt DateTime @default(now())

  // Report customization (all optional, fall back to REPORT_DEFAULTS in UI).
  reportCompanyName String?
  reportTagline     String?
  reportCtaHeadline String?
  reportCtaBody     String?
  reportCtaLabel    String?
  reportCtaUrl      String?
  reportFooterNote  String?

  audits    Audit[]
  apiKeys   ApiKey[]
}

model User {
  id             String   @id
  email          String   @unique
  organizationId String
  createdAt      DateTime @default(now())
  audits         Audit[]
}

model Audit {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User        @relation(fields: [createdById], references: [id])

  url            String
  domain         String
  status         AuditStatus @default(PENDING)

  queuedAt       DateTime    @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?

  platform           String?
  platformConfidence String?

  rawJsonKey     String?
  harFileKey     String?
  screenshotsKey String?
  pdfReportKey   String?

  overallScore   Int?
  overallGrade   String?

  findings       Finding[]
  events         Json?
  pages          Json?
  aiAnalysis     Json?
  detectedPlatforms Json?
  funnelLog      Json?

  operatorNotes  String?  @default("")
  notifyEmail    String?

  // Stagehand funnel agent token usage + model (Gemini/OpenAI/Anthropic).
  // Cost is computed on-the-fly from MODEL_PRICING — no stored cost column
  // so historical rows auto-update if a provider changes prices.
  funnelInputTokens  Int?
  funnelOutputTokens Int?
  funnelInferenceMs  Int?
  funnelModel        String?

  @@index([organizationId, queuedAt])
  @@index([status])
}

enum AuditStatus {
  PENDING
  RUNNING
  ANALYZING
  RENDERING
  COMPLETE
  FAILED
}

model Finding {
  id       String @id @default(cuid())
  auditId  String
  audit    Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)

  ruleId   String
  category String
  severity String
  status   String

  title    String
  summary  String @db.Text
  evidence Json
  impact   String? @db.Text
  fix      Json?

  @@index([auditId])
}

model ApiKey {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String

  name           String
  prefix         String
  keyHash        String        @unique

  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([keyHash])
}
