{
  "name": "@ga4-audit/audit-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "tsx": "./src/types.ts",
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./rules": {
      "tsx": "./src/rules/index.ts",
      "import": "./dist/rules/index.js",
      "types": "./dist/rules/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@ga4-audit/tsconfig": "workspace:*",
    "@types/node": "^22.19.17",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
